# Copy this file to .env before starting the local stack. Do not commit .env.

# Ktor server
HEARCHO_SERVER_HOST=0.0.0.0
HEARCHO_SERVER_PORT=8080

# PostgreSQL
POSTGRES_DB=hearcho
POSTGRES_USER=hearcho
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=hearcho
RABBITMQ_DEFAULT_PASS=change-me-for-local-development
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
